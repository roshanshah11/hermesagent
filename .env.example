# Inference — NVIDIA NIM (free models): create key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
# Optional fallback provider
OPENROUTER_API_KEY=

# Notion private api/v3 (full-account session cookie — treat like a password)
NOTION_TOKEN_V2=
NOTION_SPACE_ID=0d7b67c2-a997-815b-a8dc-0003759047bc
NOTION_USER_ID=376d872b-594c-810d-9bc6-000283650cd7

# Telegram (create bots via @BotFather; get your numeric ID from @userinfobot)
# Two-bot rule: PROD token lives ONLY on the box; the Mac dry-run uses the DEV bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_DEV=
# Gateway is default-DENY — comma-separated numeric user IDs that may talk to the bot
TELEGRAM_ALLOWED_USERS=
# Default chat for cron deliveries (numeric chat id; or run /sethome in chat once)
TELEGRAM_HOME_CHANNEL=

# Web search: NONE REQUIRED — ddgs (DuckDuckGo) is keyless and configured as the
# search backend. Optional supplement (note Hermes expects BRAVE_SEARCH_API_KEY,
# not BRAVE_API_KEY): https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=
